# =============================================
# Animind Backend - Environment Variables
# =============================================

# --- Server ---
PORT=3001
NODE_ENV=development

# --- CORS: Your frontend URL (Vercel / localhost) ---
FRONTEND_URL=http://localhost:5173,https://yourdomain.in/

# --- Supabase (same project as your frontend) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Storage: Choose ONE mode ---
# "s3"   → Videos are in an S3-compatible bucket (R2, DigitalOcean Spaces, MinIO)
# "local" → Videos sit on the VPS hard drive
STORAGE_MODE=s3

# --- S3 / Cloud Storage (used when STORAGE_MODE=s3) ---
S3_BUCKET_NAME=your-bucket-name
S3_REGION=auto
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
# How long (seconds) a presigned stream URL stays valid
S3_PRESIGN_EXPIRES=14400
# How long (seconds) a signed playback ticket stays valid (default 4 hours)
STREAM_TICKET_TTL_SECONDS=14400

# --- Local VPS Storage (used when STORAGE_MODE=local) ---
LOCAL_STORAGE_PATH=/mnt/anime

# --- Scanner ---
# How often to auto-scan (cron expression). Default: every 6 hours
SCANNER_CRON=0 */6 * * *
# Comma-separated video extensions to include
VIDEO_EXTENSIONS=mkv,mp4,avi,webm,m4v

# --- AniList (optional metadata enrichment) ---
ANILIST_ENABLED=true

# --- FFmpeg / FFprobe (for subtitle extraction) ---
# Defaults below work on Linux VPS and Docker (ffmpeg installed via package manager)
# For Windows dev: use full paths like C:/path/to/ffmpeg.exe (or leave as 'ffmpeg' if in PATH)
FFPROBE_PATH=ffprobe
FFMPEG_PATH=ffmpeg

# --- HLS Streaming (local storage mode) ---
# Segment duration in seconds (lower = faster startup, more HTTP requests)
HLS_SEGMENT_DURATION=2
# Max concurrent HLS sessions (limits ffmpeg processes)
HLS_MAX_CONCURRENT_SESSIONS=2
# Auto-expire idle sessions after this many minutes
HLS_SESSION_TIMEOUT_MINUTES=30